rules_version = '2';

// ============================================================
// VibeLens AI — Firestore Security Rules
//
// Deploy with: firebase deploy --only firestore:rules
//
// Design: the Node backend uses the Firebase ADMIN SDK, which bypasses these
// rules entirely (admin access is always trusted). These rules only govern
// what the MOBILE APP can do when it talks to Firestore directly.
//
// Key decision: the client can READ its own user doc and history (so the UI
// can show the live credit balance), but can NEVER write to credits, paid
// status, or history directly — only the backend (via /api/* routes) can
// change those, which is what stops a modified app from just granting
// itself free credits.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // all writes happen server-side via Admin SDK

      match /history/{entryId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // server-side only
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
